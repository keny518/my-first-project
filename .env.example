# Copy this to .env and fill values for local development
PG_USER=postgres
PGPASSWORD=your_db_password_here
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=my_first_project
# Optionally set DATABASE_URL instead of individual PG_* vars
# DATABASE_URL=postgres://user:password@localhost:5432/my_first_project
PORT=3000
JWT_SECRET=dev_secret_key
